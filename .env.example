# Copy this file to .env and fill in your values.
# Never commit .env — it contains real keys.

# ── Web frontend ────────────────────────────────────────────────────────────
# Base URL for coral-server when running the web frontend (npm run dev).
# Default is http://localhost:8080 — only change if you move the server.
VITE_API_URL=http://localhost:8080

# ── Helius API key ───────────────────────────────────────────────────────────
# Get a free key at https://helius.dev (100k credits/month free tier).
# Without this key the app falls back to the public Solana devnet RPC,
# which is rate-limited and slow.
VITE_HELIUS_API_KEY=

# ── CoralOS ─────────────────────────────────────────────────────────────────
# URL of a running CoralOS docker instance.
# Quick start: docker run -p 8001:8001 coralprotocol/coral-server:latest
# Then set this to http://localhost:8001.
# Leave blank to skip CoralOS integration.
CORAL_CONNECTION_URL=

# ── Python agent (for coral_agent.py MCP mode) ───────────────────────────
# Only used when running coral-agents/helius_monitor/coral_agent.py manually.
# Set by Coral when it launches the agent — you don't normally need to set it.
# CORAL_CONNECTION_URL=http://localhost:8001/mcp
WALLET=
AMOUNT_SOL=0.5
RPC_URL=
WS_URL=
HELIUS_API_KEY=
